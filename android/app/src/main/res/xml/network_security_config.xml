<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Base configuration for all connections -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system certificates (pre-installed CAs) -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- 
        Security Features:
        1. Blocks all cleartext (HTTP) traffic - enforces HTTPS only
        2. Trusts only system-installed certificates
        3. Prevents MITM attacks
        4. Complies with Google Play security requirements
    -->
    
    <!-- 
        Domain-specific configurations can be added here if needed
        Example: Allow specific domains for debugging (NOT for production)
        
        <domain-config cleartextTrafficPermitted="true">
            <domain includeSubdomains="true">localhost</domain>
            <domain includeSubdomains="true">10.0.2.2</domain>
        </domain-config>
    -->
</network-security-config>
